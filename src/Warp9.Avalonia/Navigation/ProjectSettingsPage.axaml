<ContentPage xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        TextOptions.TextRenderingMode="SubpixelAntialias"
        TextOptions.TextHintingMode="Strong"
        TextOptions.BaselinePixelAlignment="Aligned"
        x:Class="Warp9.Avalonia.ProjectSettingsPage">

<Grid ColumnDefinitions="250,*" RowDefinitions="30,30">
    <TextBlock Grid.Column="0" Grid.Row="0" VerticalAlignment="Center">External references policy</TextBlock>
    <ComboBox Grid.Column="1" Grid.Row="0" Width="200">
        <ComboBoxItem>Use absolute paths</ComboBoxItem>
        <ComboBoxItem>Use relative paths</ComboBoxItem>
        <ComboBoxItem>Convert to internal</ComboBoxItem>
    </ComboBox>

    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1">
        Changes will take effect on the next save.
    </TextBlock>
</Grid>

</ContentPage>
