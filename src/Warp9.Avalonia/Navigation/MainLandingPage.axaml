<ContentPage xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        TextOptions.TextHintingMode="Strong"
        TextOptions.TextRenderingMode="SubpixelAntialias"
        x:Class="Warp9.Avalonia.Navigation.MainLandingPage">

    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
        <Image Grid.Column="0" Grid.Row="0" Source="\Assets\warp9-logo-softdark.png" Height="56" HorizontalAlignment="Center"/>
        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Margin="0,16,0,0">Warp9.Avalonia<LineBreak/>Landing page</TextBlock>  
    </StackPanel>
</ContentPage>
