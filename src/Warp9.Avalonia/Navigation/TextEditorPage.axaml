<ContentPage xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:w9mdl="using:Warp9.Model"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Warp9.Avalonia.TextEditorPage"
        x:DataType="w9mdl:Project">

    <TextBox x:Name="txtEdit" FontFamily="Consolas" Padding="8" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding Path=Settings.Comment, Mode=OneWay}"/>
</ContentPage>
