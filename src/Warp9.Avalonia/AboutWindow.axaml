<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Width="500" Height="450" CanResize="False"        
        x:Class="Warp9.Avalonia.AboutWindow"
        Loaded="Window_Loaded"
        Title="About Warp9">

    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Margin="8">
            <Button Content="Close" HorizontalAlignment="Right" />
        </StackPanel>

        <Grid ColumnDefinitions="200,*" RowDefinitions="100,*">
            <Image Grid.Column="0" Grid.Row="0" Source="\Assets\warp9-logo-softdark.png" Height="56" HorizontalAlignment="Center"/>

            <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Orientation="Vertical">
                <TextBlock FontWeight="Bold">Warp9</TextBlock>
                <TextBlock>Version 0.0.2</TextBlock>
                <TextBlock>www.github.com/jdupej9000/warp9</TextBlock>
            </StackPanel>

             <TextBox x:Name="txtInfo" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" FontFamily="Consolas" IsReadOnly="True" BorderThickness="0" />
        </Grid>

    </DockPanel>

</Window>
