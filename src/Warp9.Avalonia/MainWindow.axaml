    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" CornerRadius="0" BorderThickness="0,0,0,1" BorderBrush="#303030" Padding="4,0,0,0">
        <Menu>
            <MenuItem Header="File">
                <MenuItem Header="_New"/>
                <MenuItem Header="_Open..." Click="FileOpen_Click">
                    <MenuItem.Icon><PathIcon Data="{StaticResource folder_open_regular}"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Save">
                     <MenuItem.Icon><PathIcon Data="{StaticResource save_regular}"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Save _As..." />
                <Separator />
                <MenuItem Header="Close" />
                <Separator />
                <MenuItem Header="_Exit" />
            </MenuItem>

            <MenuItem Header="Project">
                <MenuItem Header="Add new specimen table">
                     <MenuItem.Icon><PathIcon Data="{StaticResource table_add_regular}"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Import specimen table...">
                         <MenuItem.Icon><PathIcon Data="{StaticResource document_arrow_left_regular}"/></MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Compute">
                    <MenuItem Header="Mesh homology (DCA)" />
                    <MenuItem Header="Principal component analysis" />
                    <MenuItem Header="Point cloud distance matrix" />
                    <MenuItem Header="Landmark diagnostics" />
                </MenuItem>
            </MenuItem>

            <MenuItem Header="Tools">
                <MenuItem Header="Options">
                    <MenuItem.Icon><PathIcon Data="{StaticResource settings_regular}"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="Help">
                <MenuItem Header="_About..." Click="HelpAbout_Click">
                     <MenuItem.Icon><PathIcon Data="{StaticResource info_regular}"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="#303030" Padding="0,4" Height="28">
            <StackPanel Orientation="Horizontal">   
                <Button Background="Transparent" Height="28" Width="28" Click="Log_Click">
                    <PathIcon Data="{StaticResource book_regular}" />                  
                </Button>
                <TextBlock Text="Ready" VerticalAlignment="Center" Margin="4,0,0,0" />                
            </StackPanel>
        </Border>

        <Grid ColumnDefinitions="250,*" RowDefinitions="*">
            <TreeView Grid.Row="0" Grid.Column="0" x:Name="trvProject" x:DataType="local:Warp9ProjectModel" ItemsSource="{Binding ProjectItems}" SelectionChanged="trvProject_SelectionChanged" Margin="4,4,4,4">                                
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="local:ProjectItem">
                        <TextBlock Text="{Binding Name}"/>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <Border Grid.Row="0" Grid.Column="1" BorderThickness="1,0,0,0" BorderBrush="#303030" Padding="0">
                <ContentControl x:Name="frameMain" Margin="0" />            
            </Border>            
        </Grid>
    </DockPanel>

</Window>
